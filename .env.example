# Flask environment (development / testing / production)
FLASK_ENV=development

# Security
SECRET_KEY=secret123

# MongoDB
MONGO_URL=mongodb://localhost:27017/sensor_db
MONGO_DB_NAME=sensor_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=300

# Alerts
ALERT_TEMP_MAX=35.0
ALERT_WATER_MIN=20.0

# Cloudflare Tunnel (opcional, solo si se usa tunnel)
# CF_TUNNEL_TOKEN=
# CF_TUNNEL_DOMAIN=
